# WPA Payment Gateway — Merchant Credentials
# Copy this file to .env and fill in your values from the WPA Admin Panel

# Base URL of the WPA Gateway API
WPA_GATEWAY_URL=http://localhost:4000

# API key credentials (from Admin Panel → Merchants → API Keys → Create API Key)
# NEVER commit the real .env file to version control
WPA_CLIENT_ID=wpa_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
WPA_CLIENT_SECRET=wpa_secret_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Port for the server-example.ts local server
EXAMPLE_PORT=3001
