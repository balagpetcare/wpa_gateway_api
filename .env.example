# ─────────────────────────────────────────────────────────────────────────────
# WPA Gateway API — Environment Variables
# Copy this file to .env and fill in real values. Never commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
# Pino log level: fatal | error | warn | info | debug | trace | silent
LOG_LEVEL=info

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string. Include credentials only via env — never hard-code.
DATABASE_URL=postgresql://wpa_user:CHANGE_ME@localhost:5432/wpa_gateway

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Credential Encryption ─────────────────────────────────────────────────────
# AES-256-GCM master key. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Must be at least 32 bytes (base64-encoded). Keep this secret — rotating it
# requires re-encrypting all stored provider credentials.
CREDENTIAL_ENCRYPTION_KEY=CHANGE_ME_generate_32_random_bytes_base64

# ── JWT (Admin Auth) ──────────────────────────────────────────────────────────
# Access token signing secret. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=CHANGE_ME_at_least_48_random_bytes_hex
JWT_EXPIRES_IN=1h

# Refresh token signing secret — must be different from JWT_SECRET.
JWT_REFRESH_SECRET=CHANGE_ME_different_48_random_bytes_hex
JWT_REFRESH_EXPIRES_IN=7d

# ── HMAC ──────────────────────────────────────────────────────────────────────
# Maximum age of a merchant API request in seconds. Requests older than this
# are rejected as potential replays regardless of nonce state.
HMAC_TIMESTAMP_TOLERANCE_SECONDS=300

# How long to remember used HMAC signatures for replay detection (seconds).
# Must be >= HMAC_TIMESTAMP_TOLERANCE_SECONDS. Default 600 = 10 minutes.
NONCE_TTL_SECONDS=600

# ── CORS (Admin Panel) ────────────────────────────────────────────────────────
# Comma-separated list of origins allowed to call /admin/* endpoints.
# In production this should be the admin panel URL only.
# Example: https://admin.wpapayments.com
ADMIN_ORIGINS=http://localhost:3000
ALLOW_MOCK_PROVIDERS=false
ALLOW_INCOMPLETE_PROVIDERS=false

# Background jobs are disabled by default. Enable explicitly in environments
# where a single API instance should own operational job execution.
BACKGROUND_JOBS_ENABLED=false
JOB_SESSION_EXPIRY_ENABLED=true
JOB_SESSION_EXPIRY_INTERVAL_SECONDS=300
JOB_CALLBACK_RETRY_ENABLED=true
JOB_CALLBACK_RETRY_INTERVAL_SECONDS=300
JOB_CALLBACK_RETRY_MAX_ATTEMPTS=5
JOB_PAYOUT_STALE_REVIEW_ENABLED=true
JOB_PAYOUT_STALE_REVIEW_INTERVAL_SECONDS=900
JOB_PAYOUT_STALE_HOURS=24

# EPS sandbox placeholders for local verification only. Store these values through
# provider credentials in the admin UI instead of hardcoding them in application code.
SEED_EPS_USERNAME=sandbox-merchant@example.com
SEED_EPS_PASSWORD=CHANGE_ME
SEED_EPS_HASH_KEY=CHANGE_ME_BASE64_HASH_KEY
SEED_EPS_MERCHANT_ID=00000000-0000-0000-0000-000000000000
SEED_EPS_STORE_ID=11111111-1111-1111-1111-111111111111
SEED_EPS_BASE_URL=https://sandbox-pgapi.eps.com.bd

# Provider sandbox E2E runner guards
PROVIDER_SANDBOX_E2E_ENABLED=false
PROVIDER_SANDBOX_MODE=false
PROVIDER_SANDBOX_E2E_DRY_RUN=true
PROVIDER_SANDBOX_RETURN_URL=http://localhost:4000/api/v1/providers/sandbox/return
PROVIDER_SANDBOX_CALLBACK_URL=http://localhost:4000/api/v1/providers/sandbox/callback

# EPS sandbox
SANDBOX_EPS_USERNAME=
SANDBOX_EPS_PASSWORD=
SANDBOX_EPS_HASH_KEY=
SANDBOX_EPS_MERCHANT_ID=
SANDBOX_EPS_STORE_ID=
SANDBOX_EPS_BASE_URL=https://sandbox-pgapi.eps.com.bd
SANDBOX_EPS_TIMEOUT_MS=30000

# BKASH sandbox
SANDBOX_BKASH_APP_KEY=
SANDBOX_BKASH_APP_SECRET=
SANDBOX_BKASH_USERNAME=
SANDBOX_BKASH_PASSWORD=
SANDBOX_BKASH_BASE_URL=https://tokenized.sandbox.bka.sh/v1.2.0-beta/tokenized/checkout
SANDBOX_BKASH_TIMEOUT_MS=30000

# NAGAD sandbox
SANDBOX_NAGAD_MERCHANT_ID=
SANDBOX_NAGAD_PUBLIC_KEY=
SANDBOX_NAGAD_PRIVATE_KEY=
SANDBOX_NAGAD_BASE_URL=https://sandbox.mynagad.com:10060
SANDBOX_NAGAD_CALLBACK_URL=http://localhost:4000/api/v1/providers/nagad/callback
SANDBOX_NAGAD_TIMEOUT_MS=30000

# SSLCOMMERZ sandbox
SANDBOX_SSLCOMMERZ_STORE_ID=
SANDBOX_SSLCOMMERZ_STORE_PASSWORD=
SANDBOX_SSLCOMMERZ_BASE_URL=https://sandbox.sslcommerz.com
SANDBOX_SSLCOMMERZ_IPN_URL=http://localhost:4000/api/v1/providers/sslcommerz/ipn
SANDBOX_SSLCOMMERZ_TIMEOUT_MS=30000
